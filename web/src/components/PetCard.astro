---
// Gallery-style pet card (home + category rows). Mirrors the gallery list card.
import Icon from "./Icon.astro";
interface Pet {
  slug: string; name: string; no: number; kind: string; featured: boolean;
  tags: string[]; desc?: string; likes: number; downloads: number; usage: number;
}
const { pet: p } = Astro.props as { pet: Pet };
---
<a href={`/pet/${p.slug}`} class="card group flex flex-col overflow-hidden p-0 transition hover:-translate-y-1">
  <div class="flex items-center justify-between px-4 pt-3 font-pixel text-[11px] tracking-wide text-faint">
    <span>NO. {p.no ? String(p.no).padStart(5, "0") : "—"}</span>
    {p.featured
      ? <span class="inline-flex items-center gap-1 text-brand-600"><Icon name="star" class="h-3 w-3" /> FEATURED</span>
      : <span class="uppercase">{p.kind}</span>}
  </div>
  <div class="relative mx-4 mt-2 grid aspect-[4/5] place-items-center rounded-2xl border border-line sprite-checker ap-skel p-3">
    <canvas class="thumb h-full w-full" width="180" height="220" data-sheet={`/api/sprite/${p.slug}`}></canvas>
    <span class="states absolute bottom-2 right-2 rounded-full bg-white/90 px-2 py-0.5 font-pixel text-[10px] tracking-wide text-faint shadow-sm"></span>
  </div>
  <div class="px-4 pb-4 pt-3">
    <div class="flex items-baseline justify-between gap-2">
      <span class="truncate font-display text-lg font-semibold text-ink">{p.name}</span>
      <span class="shrink-0 font-pixel text-[10px] uppercase tracking-wide text-faint">{p.kind}</span>
    </div>
    <div class="text-xs text-faint">by community</div>
    <p class="mt-1 line-clamp-2 min-h-[2rem] text-xs text-muted">{p.desc || "A community pixel companion."}</p>
    <div class="mt-2 flex flex-wrap gap-1.5">
      {p.tags.map((t) => (
        <span class="rounded-full bg-brand-50 px-2 py-0.5 font-pixel text-[10px] lowercase text-brand-700">#{t}</span>
      ))}
    </div>
    <div class="mt-3 flex items-center gap-3 border-t border-line pt-2.5 text-xs font-medium text-muted">
      <span class="inline-flex items-center gap-1" title="Likes"><Icon name="heart" class="h-3.5 w-3.5 text-accent-500" /><span data-like-count data-slug={p.slug}>0</span></span>
    </div>
  </div>
</a>
