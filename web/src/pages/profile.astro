---
import Base from "../layouts/Base.astro";
import Icon from "../components/Icon.astro";
import Hero from "../components/Hero.astro";

export const prerender = false;
---
<Base title="My pets · AgentPet" description="Your raised companions: levels, experience and feeding stats synced from the AgentPet app." active="">
  <Hero
    eyebrow="Profile"
    icon="paw"
    title="My"
    accent="pets"
    lead="Every companion you raise keeps its own experience. Stats sync from the AgentPet app on your machine."
  />

  <section class="px-4 pt-8 pb-16">
    <div class="mx-auto max-w-6xl">

      <!-- signed out -->
      <div id="prof-signin" class="hidden">
        <div class="card mx-auto max-w-xl p-10 text-center">
          <span class="mx-auto grid h-16 w-16 place-items-center rounded-2xl bg-brand-50 text-brand-600"><Icon name="users" class="h-8 w-8" /></span>
          <h3 class="mt-5 font-display text-2xl font-bold text-ink">Sign in to see your pets</h3>
          <p class="mx-auto mt-3 max-w-md text-muted">Your companions' levels and feeding stats live on your profile once you connect the app.</p>
          <a href="/api/auth/login?returnTo=/profile" class="btn-primary mt-6 !px-6 !py-3"><Icon name="github" class="h-5 w-5" /> Sign in with GitHub</a>
          <p class="mx-auto mt-4 max-w-md text-xs text-faint">This is optional. AgentPet runs fully offline, your pet, its level and stats stay on your machine whether or not you ever sign in. Connecting only adds the web profile and leaderboard.</p>
        </div>
      </div>

      <!-- signed in -->
      <div id="prof-main" class="hidden">
        <div class="flex flex-col gap-6 lg:flex-row">
          <!-- pets -->
          <div class="min-w-0 flex-1">
            <h2 class="font-display text-2xl font-bold text-ink">Companions</h2>
            <p class="mt-1 text-sm text-muted">Each pet levels up on its own, depending on how you raise it.</p>
            <div id="prof-overview" class="mt-4 hidden grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-6"></div>
            <div id="prof-pets" class="mt-5 grid gap-4 sm:grid-cols-2"></div>
            <div id="prof-empty" class="card hidden p-8 text-center">
              <p class="font-display text-lg font-semibold text-ink">No companions yet</p>
              <p class="mx-auto mt-2 max-w-sm text-sm text-muted">Connect the AgentPet app and your pets will appear here with their levels, the moment they are fed.</p>
            </div>
          </div>

          <!-- connect card (hidden once the app is linked and pets synced) -->
          <aside id="prof-connect" class="w-full shrink-0 lg:w-80">
            <div class="card p-6">
              <h3 class="font-display text-lg font-semibold text-ink">Connect the app</h3>
              <p class="mt-2 text-sm text-muted">In AgentPet open <b class="text-ink">Settings → Care → Web profile</b> and click <b class="text-ink">Sign in with GitHub</b>. The app links itself, no codes to copy.</p>
              <p class="mt-3 text-xs text-faint">Stats refresh automatically while the app runs. Connecting is optional, AgentPet works fully offline without it.</p>
            </div>
          </aside>
        </div>
      </div>

      <div id="prof-loading" class="py-16 text-center text-sm text-faint">Loading…</div>
    </div>
  </section>

  <script>
    // Mirrors the app's level curve: reaching level n costs 60·n·(n−1) XP.
    function levelFor(xp: number): number {
      let n = 1;
      while (60 * (n + 1) * n <= xp) n++;
      return n;
    }
    function levelProgress(xp: number): number {
      const n = levelFor(xp);
      const lo = 60 * n * (n - 1);
      const hi = 60 * (n + 1) * n;
      return hi > lo ? (xp - lo) / (hi - lo) : 0;
    }
    const STAGES: [number, string, string][] = [
      [35, "Legend", "#f59e0b"],
      [20, "Hero", "#a855f7"],
      [10, "Scout", "#3b82f6"],
      [5, "Companion", "#14b8a6"],
      [0, "Hatchling", "#22c55e"],
    ];
    function stageFor(level: number): [string, string] {
      for (const [min, name, color] of STAGES) if (level >= min) return [name, color];
      return ["Hatchling", "#22c55e"];
    }
    function tokenLabel(n: number): string {
      if (n >= 1_000_000) return (n / 1_000_000).toFixed(1) + "M";
      if (n >= 1_000) return Math.round(n / 1_000) + "k";
      return String(n);
    }
    function esc(s: string): string {
      return s.replace(/[&<>"]/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" }[c] || c));
    }

    // Stage medals: a gradient disc with a white glyph, matching the app badge.
    const STAGE_ICONS: Record<string, string> = {
      Hatchling: '<path d="M12 3C8 6 6 9.5 6 13a6 6 0 0 0 12 0c0-3.5-2-7-6-10z"/>',
      Companion: '<circle cx="7" cy="9" r="2.2"/><circle cx="12" cy="6.8" r="2.2"/><circle cx="17" cy="9" r="2.2"/><path d="M12 11c-3 0-5.5 2.4-5.5 4.8 0 1.5 1.1 2.5 2.6 2.5 1 0 1.9-.4 2.9-.4s1.9.4 2.9.4c1.5 0 2.6-1 2.6-2.5C17.5 13.4 15 11 12 11z"/>',
      Scout: '<path d="M5 8h6v3H5zM13 8h6v3h-6zM7 11h4v6H7zM13 11h4v6h-4zM10.5 9h3v1.5h-3z"/>',
      Hero: '<path d="M12 2l8 3v6c0 5-3.5 8.5-8 11-4.5-2.5-8-6-8-11V5l8-3z"/>',
      Legend: '<path d="M3 17h18l-1.5-9-4.5 3.5L12 5l-3 6.5L4.5 8z"/>',
    };
    const STAGE_GRAD: Record<string, [string, string]> = {
      Hatchling: ["#4dcc73", "#2a9952"],
      Companion: ["#40ccbd", "#1a8c8c"],
      Scout: ["#5c9efa", "#2966d9"],
      Hero: ["#b073f7", "#783fd1"],
      Legend: ["#ffc747", "#eb851a"],
    };
    let gradId = 0;
    function medal(stage: string, size: number): string {
      const [a, b] = STAGE_GRAD[stage] || STAGE_GRAD.Hatchling;
      const id = `mg${gradId++}`;
      return `<svg viewBox="0 0 24 24" width="${size}" height="${size}" class="drop-shadow-sm">
        <defs><linearGradient id="${id}" x1="0" y1="0" x2="0" y2="1"><stop offset="0" stop-color="${a}"/><stop offset="1" stop-color="${b}"/></linearGradient></defs>
        <circle cx="12" cy="12" r="11" fill="url(#${id})" stroke="#ffffff88" stroke-width="1"/>
        <ellipse cx="12" cy="8" rx="6" ry="3" fill="#ffffff44"/>
        <g transform="translate(4 4) scale(0.66)" fill="#fff">${STAGE_ICONS[stage] || ""}</g>
      </svg>`;
    }

    // Achievements — keys, an SVG glyph matching the app's SF Symbol, name and
    // hint, mirroring PetCare.Achievement / PetCare.achievementSymbol. Glyph
    // paths are Lucide (MIT), the closest open equivalents to the SF Symbols.
    const ICON: Record<string, string> = {
      "fork.knife": '<path d="M3 2v7c0 1.1.9 2 2 2a2 2 0 0 0 2-2V2"/><path d="M7 2v20"/><path d="M21 15V2a5 5 0 0 0-5 5v6c0 1.1.9 2 2 2h3Zm0 0v7"/>',
      "trophy": '<path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/>',
      "flame": '<path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/>',
      "bolt": '<path d="M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z"/>',
      "star": '<path d="M11.5 2.3a.5.5 0 0 1 .95 0l2.3 4.68a2.1 2.1 0 0 0 1.6 1.16l5.17.76a.53.53 0 0 1 .29.9l-3.74 3.64a2.1 2.1 0 0 0-.6 1.88l.88 5.14a.53.53 0 0 1-.77.56l-4.62-2.43a2.1 2.1 0 0 0-1.97 0L6.4 21a.53.53 0 0 1-.77-.56l.88-5.14a2.1 2.1 0 0 0-.61-1.88L2.16 9.8a.53.53 0 0 1 .29-.9l5.17-.76a2.1 2.1 0 0 0 1.6-1.16z"/>',
      "shield": '<path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/>',
      "crown": '<path d="M11.56 3.27a.5.5 0 0 1 .88 0l2.95 5.6a1 1 0 0 0 1.52.3l4.28-3.67a.5.5 0 0 1 .8.52l-2.84 10.25a1 1 0 0 1-.95.73H5.81a1 1 0 0 1-.96-.73L2.02 6.02a.5.5 0 0 1 .8-.52l4.28 3.67a1 1 0 0 0 1.52-.3z"/><path d="M5 21h14"/>',
      "calendar": '<path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/>',
      "calendar.clock": '<path d="M21 7.5V6a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h3.5"/><path d="M16 2v4"/><path d="M8 2v4"/><path d="M3 10h5"/><circle cx="16" cy="16" r="6"/><path d="M16 14v2l1.5 1.2"/>',
      "calendar.check": '<path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/><path d="m9 16 2 2 4-4"/>',
      "moon": '<path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/>',
    };
    const ACHIEVEMENTS: [string, string, string, string][] = [
      ["firstMeal", "fork.knife", "First Meal", "Finish your first agent session"],
      ["sessions100", "trophy", "100 Sessions", "Finish 100 agent sessions"],
      ["sessions500", "trophy", "500 Sessions", "Finish 500 agent sessions"],
      ["tokens1M", "flame", "1M Tokens", "Burn 1M tokens"],
      ["tokens10M", "flame", "10M Tokens", "Burn 10M tokens"],
      ["tokens50M", "bolt", "50M Tokens", "Burn 50M tokens"],
      ["level5", "star", "Level 5", "Reach Level 5"],
      ["level10", "star", "Level 10", "Reach Level 10"],
      ["level20", "shield", "Level 20", "Reach Level 20"],
      ["level35", "crown", "Level 35", "Reach Level 35 (Legend)"],
      ["streak7", "calendar", "7-Day Streak", "Feed your pet 7 days in a row"],
      ["streak14", "calendar.clock", "14-Day Streak", "Feed your pet 14 days in a row"],
      ["streak30", "calendar.check", "30-Day Streak", "Feed your pet 30 days in a row"],
      ["nightOwl", "moon", "Night Owl", "Finish a session after midnight"],
    ];

    // Authoritative set is what the app synced; fall back to deriving from stats
    // for pets synced before achievements existed (Night Owl can't be derived).
    function unlockedSet(p: any): Set<string> {
      if (Array.isArray(p.achievements)) return new Set(p.achievements);
      const dispLv = Math.max(0, levelFor(p.xp) - 1);
      const s = new Set<string>();
      if (p.meals >= 1) s.add("firstMeal");
      if (p.meals >= 100) s.add("sessions100");
      if (p.meals >= 500) s.add("sessions500");
      if (p.tokens >= 1_000_000) s.add("tokens1M");
      if (p.tokens >= 10_000_000) s.add("tokens10M");
      if (p.tokens >= 50_000_000) s.add("tokens50M");
      if (dispLv >= 5) s.add("level5");
      if (dispLv >= 10) s.add("level10");
      if (dispLv >= 20) s.add("level20");
      if (dispLv >= 35) s.add("level35");
      if (p.streak >= 7) s.add("streak7");
      if (p.streak >= 14) s.add("streak14");
      if (p.streak >= 30) s.add("streak30");
      return s;
    }

    // Mirrors the app's right-click HUD badge row: a strip of icon-only badges,
    // unlocked tinted in the stage color, locked dimmed. Native hover tooltip
    // shows the name + how to unlock it.
    function badgeRow(p: any, color: string): string {
      const have = unlockedSet(p);
      const chips = ACHIEVEMENTS.map(([key, icon, name, hint]) => {
        const on = have.has(key);
        const title = `${name} — ${on ? "Unlocked" : hint}`;
        const svg = `<svg viewBox="0 0 24 24" width="15" height="15" fill="none"
          stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">${ICON[icon] || ICON.star}</svg>`;
        return `<span title="${esc(title)}" aria-label="${esc(title)}"
          class="grid h-7 w-7 place-items-center rounded-lg transition"
          style="background:${on ? color + "1f" : "#00000008"};color:${on ? color : "#9aa3b2"};opacity:${on ? 1 : 0.45}">${svg}</span>`;
      }).join("");
      return `
        <div class="mt-3">
          <div class="flex items-center justify-between">
            <span class="text-[10px] font-semibold uppercase tracking-wide text-faint">Badges</span>
            <span class="text-[10px] font-semibold" style="color:${color}">${have.size} / ${ACHIEVEMENTS.length}</span>
          </div>
          <div class="mt-1.5 flex flex-wrap gap-1.5">${chips}</div>
        </div>`;
    }

    function petCard(p: any): string {
      const lv = levelFor(p.xp);
      const dispLv = Math.max(0, lv - 1);
      const [stage, color] = stageFor(lv);
      const pct = Math.round(levelProgress(p.xp) * 100);
      const next = 60 * (lv + 1) * lv;
      const floor = 60 * lv * (lv - 1);
      const inLevel = Math.max(0, p.xp - floor);   // XP earned in this level
      const span = Math.max(1, next - floor);      // XP needed to clear it
      const fed = p.lastFedAt ? new Date(p.lastFedAt).toLocaleDateString() : null;
      const thumb = p.thumb
        ? `<img src="${p.thumb}" alt="" class="pixel-art h-16 w-16 object-contain" />`
        : `<svg viewBox="0 0 24 24" class="h-8 w-8" fill="${color}">${STAGE_ICONS[stage]}</svg>`;
      const toNext = Math.max(0, (next - p.xp) * 5000);
      return `
        <div class="card p-5">
          <div class="flex items-center gap-3">
            <div class="relative grid h-20 w-20 shrink-0 place-items-center rounded-2xl" style="background:${color}14">
              ${thumb}
              <div class="absolute -bottom-1 -right-1">${medal(stage, 26)}</div>
            </div>
            <div class="min-w-0 flex-1">
              <div class="truncate font-display text-lg font-semibold text-ink">${esc(p.name)}</div>
              <span class="mt-1 inline-flex items-center gap-1 rounded-full px-2 py-0.5 text-[11px] font-bold" style="background:${color}1f;color:${color}">
                ${medal(stage, 13)}${stage}
              </span>
            </div>
            <div class="relative grid h-14 w-14 shrink-0 place-items-center">
              <svg viewBox="0 0 64 64" class="absolute inset-0 h-full w-full">
                <polygon points="32,3 58,17 58,47 32,61 6,47 6,17" fill="${color}1c" stroke="${color}" stroke-width="2.5" stroke-linejoin="round"/>
              </svg>
              <div class="relative text-center leading-none">
                <div class="text-[9px] font-bold uppercase tracking-wide" style="color:${color}">Lv</div>
                <div class="font-display text-xl font-bold text-ink">${dispLv}</div>
              </div>
            </div>
          </div>
          <div class="mt-3 h-2 overflow-hidden rounded-full bg-brand-50">
            <div class="h-full rounded-full" style="width:${pct}%;background:${color}"></div>
          </div>
          <div class="mt-1 flex justify-between text-[11px] text-faint">
            <span>${inLevel.toLocaleString()} / ${span.toLocaleString()} XP</span>
            <span>${pct}%</span>
          </div>
          <p class="mt-1 text-[11px] font-medium" style="color:${color}">≈ ${tokenLabel(toNext)} tokens to Lv ${dispLv + 1}</p>
          <dl class="mt-3 grid grid-cols-3 gap-2 text-center">
            <div class="rounded-xl bg-brand-50/60 px-2 py-2" title="${p.tokens.toLocaleString()} tokens">
              <dt class="text-[10px] font-semibold uppercase tracking-wide text-faint">Tokens</dt>
              <dd class="text-sm font-bold text-ink">${tokenLabel(p.tokens)}</dd>
            </div>
            <div class="rounded-xl bg-brand-50/60 px-2 py-2">
              <dt class="text-[10px] font-semibold uppercase tracking-wide text-faint">Sessions</dt>
              <dd class="text-sm font-bold text-ink">${p.meals.toLocaleString()}</dd>
            </div>
            <div class="rounded-xl bg-brand-50/60 px-2 py-2">
              <dt class="text-[10px] font-semibold uppercase tracking-wide text-faint">Streak</dt>
              <dd class="text-sm font-bold text-ink">${p.streak}d</dd>
            </div>
          </dl>
          ${sparkline(p.week, color)}
          ${badgeRow(p, color)}
          ${fed ? `<p class="mt-3 text-xs text-faint">Last fed ${fed}</p>` : ""}
        </div>`;
    }

    // A small 7-day burn sparkline (bars), drawn inline.
    function sparkline(week: number[] | null, color: string): string {
      if (!Array.isArray(week) || week.length === 0 || week.every((n) => !n)) return "";
      const peak = Math.max(...week, 1);
      const bars = week
        .map((v, i) => {
          const h = Math.max(2, Math.round((v / peak) * 26));
          const last = i === week.length - 1;
          return `<div class="flex-1 rounded-sm" style="height:${h}px;background:${color};opacity:${last ? 1 : 0.4}"></div>`;
        })
        .join("");
      return `
        <div class="mt-3">
          <div class="flex items-center justify-between text-[10px] text-faint">
            <span class="font-semibold uppercase tracking-wide">Burn · 7 days</span>
            <span>${tokenLabel(week.reduce((s, n) => s + n, 0))}</span>
          </div>
          <div class="mt-1 flex items-end gap-1" style="height:28px">${bars}</div>
        </div>`;
    }

    function renderOverview(pets: any[]) {
      const box = document.getElementById("prof-overview");
      if (!box) return;
      const totalXp = pets.reduce((s, p) => s + p.xp, 0);
      const totalTokens = pets.reduce((s, p) => s + p.tokens, 0);
      const best = pets.reduce((a, p) => (p.xp > (a?.xp ?? -1) ? p : a), null as any);
      const bestLv = best ? Math.max(0, levelFor(best.xp) - 1) : 0;
      const totalSessions = pets.reduce((s, p) => s + p.meals, 0);
      const bestStreak = pets.reduce((m, p) => Math.max(m, p.streak), 0);
      const cells = [
        ["Companions", String(pets.length), "#3b82f6"],
        ["Total level", String(pets.reduce((s, p) => s + Math.max(0, levelFor(p.xp) - 1), 0)), "#a855f7"],
        ["Total tokens", tokenLabel(totalTokens), "#14b8a6"],
        ["Sessions", String(totalSessions), "#22c55e"],
        ["Best streak", bestStreak + "d", "#f59e0b"],
        ["Top pet", best ? `${esc(best.name)} · Lv ${bestLv}` : "—", "#ec4899"],
      ];
      box.innerHTML = cells
        .map(
          ([label, value, c]) => `
          <div class="card px-4 py-3" style="border-top:3px solid ${c}">
            <div class="text-[10px] font-semibold uppercase tracking-wide text-faint">${label}</div>
            <div class="mt-0.5 truncate font-display text-lg font-bold text-ink">${value}</div>
          </div>`
        )
        .join("");
      box.classList.remove("hidden");
      box.classList.add("grid");
    }

    async function load() {
      const me = await fetch("/api/me.json").then((r) => r.json()).catch(() => null);
      document.getElementById("prof-loading")?.classList.add("hidden");
      if (!me?.user) {
        document.getElementById("prof-signin")?.classList.remove("hidden");
        (window as any).AP_I18N?.apply?.();
        return;
      }
      document.getElementById("prof-main")?.classList.remove("hidden");

      const data = await fetch("/api/care/me.json").then((r) => r.json()).catch(() => ({ pets: [] }));
      const pets = data?.pets ?? [];
      const grid = document.getElementById("prof-pets")!;
      if (pets.length) {
        grid.innerHTML = pets.map(petCard).join("");
        renderOverview(pets);
        // Already linked and syncing: the connect walkthrough is just noise.
        document.getElementById("prof-connect")?.classList.add("hidden");
      } else {
        document.getElementById("prof-empty")?.classList.remove("hidden");
      }
      (window as any).AP_I18N?.apply?.();
    }

    load();
  </script>
</Base>
