---
import Base from "../layouts/Base.astro";
import Icon from "../components/Icon.astro";
import Hero from "../components/Hero.astro";
const DISCORD = "https://discord.gg/kzFJKsZav";
const steps = [
  { icon: "wand", title: "Design a spritesheet", body: "One transparent PNG. Each row is an animation (idle, running, waving…), each column a frame, with clear transparent gaps between frames." },
  { icon: "sparkles", title: "Add a pet.json", body: "A tiny manifest: id, displayName, and description, packed next to the spritesheet. AgentPet maps each row to a state." },
  { icon: "paw", title: "Share it", body: "Upload your spritesheet on the Submit page. Once approved it joins the gallery, credited to you. The pet-pack format is open; artwork stays with its creator." },
];
const prompt = `Draw a chibi pixel-art desktop pet as ONE transparent PNG spritesheet.
- Each ROW is an animation (idle, run, jump, wave, waiting), frames left to right.
- Fully transparent background, clear gaps between every frame, consistent frame size.
- Character: [describe your pet here].
Output a single transparent PNG.`;
---
<Base title="Make a pet · AgentPet" description="Create and share your own pixel companion." active="make">
  <Hero
    eyebrow="Open format · Community-made"
    icon="wand"
    title="Make your own"
    accent="pixel pet"
    lead="A pet is just one transparent spritesheet plus a tiny manifest. Pick a path: have an AI generate it, or upload a sheet you drew and preview the animations right here."
  >
    <a href="#ai" class="btn-primary !px-6 !py-3"><Icon name="sparkles" class="h-5 w-5" /> Generate with AI</a>
    <a href="#upload" class="btn-ghost !px-6 !py-3"><Icon name="download" class="h-5 w-5 rotate-180" /> Upload a sheet</a>
  </Hero>

  <!-- format steps -->
  <section class="px-4 pt-8">
    <div class="mx-auto grid max-w-6xl gap-5 md:grid-cols-3">
      {steps.map((s, i) => (
        <div class="card p-7">
          <div class="grid h-12 w-12 place-items-center rounded-2xl bg-brand-50 text-brand-600"><Icon name={s.icon} class="h-6 w-6" /></div>
          <div class="mt-4 font-display text-xs font-bold uppercase tracking-wide text-brand-500">Step {i + 1}</div>
          <h3 class="mt-1 font-display text-xl font-semibold text-ink">{s.title}</h3>
          <p class="mt-2 text-muted">{s.body}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- two ways to make one -->
  <section class="px-4 pt-12">
    <div class="mx-auto max-w-6xl">
      <h2 class="font-display text-2xl font-bold text-ink">Two ways to make one</h2>
      <p class="mt-1 text-muted">Generate a sheet with AI, or bring your own and check the frames before you share it.</p>

      <div class="mt-6 grid gap-5 lg:grid-cols-2">
        <!-- A: generate with AI -->
        <div id="ai" class="card flex flex-col p-7">
          <div class="flex items-center gap-3">
            <span class="grid h-10 w-10 place-items-center rounded-xl bg-brand-50 text-brand-600"><Icon name="sparkles" class="h-5 w-5" /></span>
            <div>
              <div class="font-pixel text-[11px] uppercase tracking-wide text-brand-500">Option A</div>
              <h3 class="font-display text-xl font-semibold text-ink">Generate with AI</h3>
            </div>
          </div>
          <p class="mt-3 text-sm text-muted">Paste this into any image AI, then upload the result in Option B to preview the animations.</p>
          <pre id="prompt" class="mt-4 flex-1 overflow-x-auto rounded-2xl bg-brand-50/70 p-4 font-mono text-sm text-ink">{prompt}</pre>
          <button id="copyPrompt" class="btn-ghost mt-4 self-start !px-5 !py-2.5 text-sm"><Icon name="search" class="h-4 w-4" /> Copy prompt</button>
        </div>

        <!-- B: upload & preview -->
        <div id="upload" class="card flex flex-col p-7">
          <div class="flex items-center gap-3">
            <span class="grid h-10 w-10 place-items-center rounded-xl bg-brand-50 text-brand-600"><Icon name="download" class="h-5 w-5 rotate-180" /></span>
            <div>
              <div class="font-pixel text-[11px] uppercase tracking-wide text-brand-500">Option B</div>
              <h3 class="font-display text-xl font-semibold text-ink">Upload &amp; preview</h3>
            </div>
          </div>
          <p class="mt-3 text-sm text-muted">Drop a transparent PNG/WebP spritesheet. We slice it by row into animation states, right in your browser, nothing is uploaded.</p>

          <label id="dropzone" class="group mt-4 flex cursor-pointer flex-col items-center justify-center gap-2 rounded-2xl border-2 border-dashed border-line bg-brand-50/40 px-6 py-10 text-center transition hover:border-brand-300 hover:bg-brand-50">
            <span class="grid h-12 w-12 place-items-center rounded-2xl bg-white text-brand-600 shadow-soft transition group-hover:scale-105"><Icon name="download" class="h-6 w-6 rotate-180" /></span>
            <span class="font-display font-semibold text-ink">Choose a spritesheet</span>
            <span class="text-sm text-faint">PNG or WebP, transparent background</span>
            <input id="fileInput" type="file" accept="image/png,image/webp,image/*" class="hidden" />
          </label>

          <div id="upError" class="mt-3 hidden rounded-xl bg-accent-500/10 px-4 py-3 text-sm text-accent-600"></div>

          <div id="upResult" class="mt-4 hidden">
            <div class="grid gap-4 sm:grid-cols-[180px_1fr]">
              <div class="grid place-items-center rounded-2xl border border-line p-3 sprite-checker">
                <canvas id="upMain" class="h-40 w-full" width="220" height="200"></canvas>
              </div>
              <div>
                <div class="flex items-center justify-between">
                  <div class="font-display text-base font-bold text-ink" id="upState">Idle</div>
                  <span class="font-pixel text-[11px] tracking-wide text-faint"><span id="upCount">0</span> states detected</span>
                </div>
                <div id="upStates" class="mt-3 flex max-h-44 flex-wrap gap-2 overflow-y-auto"></div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- share -->
      <div class="mt-6 relative overflow-hidden rounded-[2rem] bg-gradient-to-br from-brand-600 to-brand-500 p-10 text-center text-white shadow-card">
        <h2 class="font-display text-3xl font-bold text-white">Got a pet to share?</h2>
        <p class="mx-auto mt-2 max-w-md text-brand-100">Upload your spritesheet and we'll review it. Approved pets join the gallery, credited to your GitHub.</p>
        <div class="mt-6 flex flex-wrap justify-center gap-3">
          <a href="/submit" class="btn !bg-white !px-6 !py-3.5 text-base font-semibold text-brand-700"><Icon name="download" class="h-5 w-5 rotate-180" /> Submit a pet</a>
          <a href={DISCORD} target="_blank" rel="noopener" class="btn !px-6 !py-3.5 text-base font-semibold text-white" style="border:1px solid rgba(255,255,255,.5)"><Icon name="discord" class="h-5 w-5" /> Ask on Discord</a>
        </div>
      </div>
    </div>
  </section>

  <script>
    // Copy prompt
    const btn = document.getElementById("copyPrompt");
    btn?.addEventListener("click", () => {
      const txt = document.getElementById("prompt")?.textContent ?? "";
      navigator.clipboard.writeText(txt).then(() => { const o = btn.innerHTML; btn.textContent = "Copied!"; setTimeout(() => { btn.innerHTML = o; }, 1500); }).catch(() => {});
    });

    // ---- Upload & slice preview (same row/frame detection as the app) ----
    type Frame = { x: number; y: number; w: number; h: number };
    const NAMES = ["Idle", "Run Right", "Run Left", "Waving", "Jumping", "Failed", "Waiting", "Running", "Review"];
    function seg(arr: boolean[]) { const r: [number, number][] = []; let s: number | null = null; for (let i = 0; i < arr.length; i++) { if (arr[i] && s === null) s = i; else if (!arr[i] && s !== null) { r.push([s, i]); s = null; } } if (s !== null) r.push([s, arr.length]); return r; }
    function sliceRows(img: HTMLImageElement) {
      const w = img.naturalWidth, h = img.naturalHeight, TH = 16;
      const off = document.createElement("canvas"); off.width = w; off.height = h;
      const o = off.getContext("2d")!; o.drawImage(img, 0, 0);
      let px: Uint8ClampedArray; try { px = o.getImageData(0, 0, w, h).data; } catch { return null; }
      const rowHas: boolean[] = new Array(h).fill(false);
      for (let y = 0; y < h; y++) { const b = y * w * 4; for (let x = 0; x < w; x++) if (px[b + x * 4 + 3] > TH) { rowHas[y] = true; break; } }
      const rows: Frame[][] = [];
      for (const [y0, y1] of seg(rowHas)) {
        const colHas: boolean[] = new Array(w).fill(false);
        for (let x = 0; x < w; x++) for (let y = y0; y < y1; y++) if (px[(y * w + x) * 4 + 3] > TH) { colHas[x] = true; break; }
        const fr = seg(colHas).map(([x0, x1]) => ({ x: x0, y: y0, w: x1 - x0, h: y1 - y0 }));
        if (fr.length) rows.push(fr);
      }
      return rows;
    }
    function drawFrame(ctx: CanvasRenderingContext2D, cv: HTMLCanvasElement, img: HTMLImageElement, f: Frame, fill: number) {
      ctx.clearRect(0, 0, cv.width, cv.height);
      const s = Math.min(cv.width / f.w, cv.height / f.h) * fill, dw = f.w * s, dh = f.h * s;
      ctx.drawImage(img, f.x, f.y, f.w, f.h, (cv.width - dw) / 2, (cv.height - dh) / 2, dw, dh);
    }

    const input = document.getElementById("fileInput") as HTMLInputElement | null;
    const result = document.getElementById("upResult");
    const errBox = document.getElementById("upError");
    const upMain = document.getElementById("upMain") as HTMLCanvasElement | null;
    const upStates = document.getElementById("upStates");
    let timer: number | null = null;

    function showErr(msg: string) { if (!errBox) return; errBox.textContent = msg; errBox.classList.remove("hidden"); result?.classList.add("hidden"); }

    input?.addEventListener("change", () => {
      const file = input.files?.[0]; if (!file) return;
      errBox?.classList.add("hidden");
      const url = URL.createObjectURL(file);
      const img = new Image();
      img.onload = () => {
        const rows = sliceRows(img);
        URL.revokeObjectURL(url);
        if (!rows || !rows.length) { showErr("Couldn't detect any frames. Make sure the background is transparent with gaps between frames."); return; }
        result?.classList.remove("hidden");
        const setText = (id: string, t: string) => { const el = document.getElementById(id); if (el) el.textContent = t; };
        setText("upCount", String(rows.length));

        const mctx = upMain!.getContext("2d")!; mctx.imageSmoothingEnabled = false;
        const playRow = (i: number) => {
          if (timer) { clearInterval(timer); timer = null; }
          const frames = rows[i]; let idx = 0; drawFrame(mctx, upMain!, img, frames[0], 0.9);
          if (frames.length > 1) timer = window.setInterval(() => { idx = (idx + 1) % frames.length; drawFrame(mctx, upMain!, img, frames[idx], 0.9); }, 150);
          setText("upState", (NAMES[i] ?? `State ${i + 1}`) + ` · ${frames.length} ${frames.length === 1 ? "frame" : "frames"}`);
          upStates!.querySelectorAll("button").forEach((b) => b.classList.toggle("chip-active", Number((b as HTMLElement).dataset.row) === i));
        };

        upStates!.innerHTML = "";
        rows.forEach((frames, i) => {
          const b = document.createElement("button");
          b.type = "button"; b.dataset.row = String(i);
          b.className = "chip capitalize";
          b.textContent = `${NAMES[i] ?? "State " + (i + 1)} (${frames.length})`;
          b.addEventListener("click", () => playRow(i));
          upStates!.appendChild(b);
        });
        playRow(0);
      };
      img.onerror = () => { URL.revokeObjectURL(url); showErr("That file couldn't be loaded as an image."); };
      img.src = url;
    });
  </script>
</Base>
