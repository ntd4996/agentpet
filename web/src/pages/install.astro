---
import Base from "../layouts/Base.astro";
import Icon from "../components/Icon.astro";
import Hero from "../components/Hero.astro";
import CodeBlock from "../components/CodeBlock.astro";

const GITHUB = "https://github.com/ntd4996/agentpet";
const RELEASES = "https://github.com/ntd4996/agentpet/releases";
const RELEASE_LATEST = "https://github.com/ntd4996/agentpet/releases/latest";
const DISCORD = "https://discord.gg/kzFJKsZav";
const BREW = "brew install --cask ntd4996/tap/agentpet";
const WIN_TAG = "win-v0.1.5";
const WIN_SETUP = `https://github.com/ntd4996/agentpet/releases/download/${WIN_TAG}/AgentPet_0.1.5_x64-setup.exe`;
const WIN_PORTABLE = `https://github.com/ntd4996/agentpet/releases/download/${WIN_TAG}/AgentPet-portable-x64.zip`;

const LINUX_TAG = "linux-v0.1.5";
const LINUX_BASE = `https://github.com/ntd4996/agentpet/releases/download/${LINUX_TAG}`;
const LINUX_APPIMAGE = `${LINUX_BASE}/AgentPet_0.1.5_amd64.AppImage`;
const LINUX_DEB = `${LINUX_BASE}/AgentPet_0.1.5_amd64.deb`;
const LINUX_RPM = `${LINUX_BASE}/AgentPet-0.1.5-1.x86_64.rpm`;

const platforms = [
  { id: "macos", label: "macOS", icon: "apple", status: "Available" },
  { id: "windows", label: "Windows", icon: "windows", status: "Available" },
  { id: "linux", label: "Linux", icon: "linux", status: "Available" },
];

const linuxRequirements = [
  "A 64-bit desktop distro (Ubuntu/Debian, Fedora, or anything that runs an AppImage).",
  "A compositor with transparency (standard on GNOME, KDE, and most desktops).",
  "GTK 3 + WebKit2GTK 4.1 (the .deb/.rpm pull these in; the AppImage bundles what it can).",
  "System-tray support (install a GNOME AppIndicator extension if your tray is missing).",
];

const winRequirements = [
  "Windows 10 or 11, 64-bit.",
  "WebView2 runtime (preinstalled on Windows 11, the installer fetches it on Windows 10).",
  "Updates itself: check from the pet's right-click menu → Updates.",
  "Per-user install, no admin rights needed.",
];

const requirements = [
  "macOS 13 Ventura or later (macOS 14 Sonoma+ recommended).",
  "Apple Silicon (M1 to M4) and Intel Macs are both supported.",
  "Developer ID-signed and notarized, so it opens without a Gatekeeper warning.",
  "Updates itself: checks automatically, or update in-app from the menu bar.",
];

const firstRun = [
  { t: "Open AgentPet", b: "Your pet lands in the menu bar. Click the icon to open Settings." },
  { t: "Connect an agent", b: "In Settings → General, click Install next to Claude Code (or your tool)." },
  { t: "Enable notifications", b: "Allow notifications so the pet can ping you when an agent needs input." },
];

const firstRunWin = [
  { t: "Open AgentPet", b: "Your pet lands on the desktop and an icon appears in the system tray. Click the tray icon to open Settings." },
  { t: "Connect an agent", b: "In Settings → General, click Install next to Claude Code (or your tool)." },
  { t: "Enable notifications", b: "Allow notifications so the pet can ping you when an agent needs input." },
];

const firstRunLinux = [
  { t: "Open AgentPet", b: "Your pet lands on the desktop and an icon appears in the system tray. Click the tray icon to open Settings." },
  { t: "Connect an agent", b: "In Settings → General, click Install next to Claude Code (or your tool)." },
  { t: "Enable notifications", b: "Allow notifications so the pet can ping you when an agent needs input." },
];

const LINUX_ONELINE = `curl -fsSL https://agentpet.thenightwatcher.online/install.sh | sh`;

const LINUX_RUN = `# AppImage , works on any distro
chmod +x AgentPet_0.1.5_amd64.AppImage
./AgentPet_0.1.5_amd64.AppImage

# Debian / Ubuntu
sudo dpkg -i AgentPet_0.1.5_amd64.deb

# Fedora / openSUSE
sudo rpm -i AgentPet-0.1.5-1.x86_64.rpm`;

const UNINSTALL = `brew uninstall --cask agentpet
rm -rf ~/.agentpet
rm -f  ~/Library/Preferences/com.agentpet.app.plist`;

const BUILD = `git clone https://github.com/ntd4996/agentpet.git
cd agentpet
./scripts/build-app.sh release
open build/AgentPet.app`;
---
<Base title="Install AgentPet · download for macOS, Windows & Linux" description="Download and install AgentPet for macOS, Windows, or Linux. Homebrew, a notarized DMG, a Windows installer, or an AppImage / .deb / .rpm." active="">
  <Hero
    eyebrow="Download"
    icon="download"
    title="Install"
    accent="AgentPet"
    lead="Adopt a pixel companion for your AI coding agents. Free and open source, for macOS, Windows, and Linux. Pick your platform below."
  >
    <a href={RELEASE_LATEST} target="_blank" rel="noopener" data-os-cta="macos" class="btn-primary !px-6 !py-3.5 text-base"><Icon name="apple" class="h-5 w-5" /> Download for macOS</a>
    <a href={WIN_SETUP} data-os-cta="windows" class="btn-primary hidden !px-6 !py-3.5 text-base"><Icon name="windows" class="h-5 w-5" /> Download for Windows</a>
    <a href={LINUX_APPIMAGE} data-os-cta="linux" class="btn-primary hidden !px-6 !py-3.5 text-base"><Icon name="linux" class="h-5 w-5" /> Download for Linux</a>
    <a href={GITHUB} target="_blank" rel="noopener" class="btn-ghost !px-6 !py-3.5 text-base"><Icon name="github" class="h-4 w-4" /> Star on GitHub</a>
  </Hero>

  <!-- platform tabs -->
  <section id="get" class="scroll-mt-28 px-4 pt-10">
    <div class="mx-auto max-w-6xl">
      <div role="tablist" aria-label="Choose your platform" class="mx-auto flex w-fit items-center gap-1.5 rounded-full border border-line bg-white p-1.5 shadow-soft">
        {platforms.map((p, i) => (
          <button
            type="button"
            role="tab"
            data-tab={p.id}
            aria-selected={i === 0 ? "true" : "false"}
            class={`tab-btn inline-flex items-center gap-2 rounded-full px-4 py-2.5 text-sm font-semibold transition ${i === 0 ? "bg-brand-600 text-white shadow-soft" : "text-muted hover:bg-brand-50 hover:text-brand-700"}`}
          >
            <Icon name={p.icon} class="h-4 w-4" />
            {p.label}
            <span class={`rounded-full px-2 py-0.5 text-[10px] font-bold uppercase tracking-wide ${p.status === "Available" ? (i === 0 ? "bg-white/20 text-white" : "bg-mint-400/15 text-emerald-600") : "bg-sun-400/20 text-amber-600"}`}>{p.status}</span>
          </button>
        ))}
      </div>

      <!-- macOS panel -->
      <div data-panel="macos" class="tab-panel mt-8">
        <div class="text-center">
          <h3 class="font-display text-2xl font-bold text-ink">Two ways to install, pick one</h3>
          <p class="mx-auto mt-2 max-w-md text-muted">Run one Homebrew command, or download the app directly. You only need one of them.</p>
        </div>

        <div class="mt-7 flex flex-col items-stretch gap-5 md:flex-row">
          <div class="card relative flex flex-1 flex-col p-7">
            <span class="absolute right-5 top-6 rounded-full bg-mint-400/15 px-2.5 py-1 text-[10px] font-bold uppercase tracking-wide text-emerald-600">Recommended</span>
            <span class="grid h-12 w-12 place-items-center rounded-2xl bg-brand-50 text-brand-600"><Icon name="terminal" class="h-6 w-6" /></span>
            <div class="mt-4 font-pixel text-[11px] uppercase tracking-wide text-brand-500">Option 1</div>
            <h3 class="mt-0.5 font-display text-xl font-semibold text-ink">Homebrew</h3>
            <p class="mt-2 flex-1 text-muted">The quickest install. The cask drops AgentPet into Applications and keeps it upgradable.</p>
            <CodeBlock code={BREW} class="mt-4" />
            <p class="mt-3 text-sm text-faint">Update later with <code class="rounded bg-brand-50 px-1.5 py-0.5 font-mono text-xs text-brand-700">brew upgrade --cask agentpet</code></p>
          </div>

          <!-- either / or divider -->
          <div class="flex items-center justify-center gap-3 md:flex-col">
            <span class="h-px flex-1 bg-line md:h-auto md:w-px md:flex-1"></span>
            <span class="grid h-9 w-9 shrink-0 place-items-center rounded-full border border-line bg-white text-[11px] font-bold uppercase text-faint shadow-soft">or</span>
            <span class="h-px flex-1 bg-line md:h-auto md:w-px md:flex-1"></span>
          </div>

          <div class="card flex flex-1 flex-col p-7">
            <span class="grid h-12 w-12 place-items-center rounded-2xl bg-brand-50 text-brand-600"><Icon name="download" class="h-6 w-6" /></span>
            <div class="mt-4 font-pixel text-[11px] uppercase tracking-wide text-brand-500">Option 2</div>
            <h3 class="mt-0.5 font-display text-xl font-semibold text-ink">Direct download</h3>
            <p class="mt-2 flex-1 text-muted">Grab the notarized <code class="rounded bg-brand-50 px-1.5 py-0.5 font-mono text-xs text-brand-700">AgentPet.dmg</code>, open it, and drag AgentPet to your Applications folder.</p>
            <a href={RELEASE_LATEST} target="_blank" rel="noopener" class="btn-primary mt-4 w-full"><Icon name="apple" class="h-5 w-5" /> Download .dmg</a>
            <a href={RELEASES} target="_blank" rel="noopener" class="mt-3 inline-flex items-center gap-1 self-start text-sm font-semibold text-brand-600 hover:text-brand-700">Browse all releases <Icon name="arrow" class="h-4 w-4" /></a>
          </div>
        </div>

        <!-- requirements -->
        <div class="card mt-5 p-7">
          <h3 class="font-display text-lg font-semibold text-ink">What you need</h3>
          <ul class="mt-4 grid gap-3 sm:grid-cols-2">
            {requirements.map((r) => (
              <li class="flex items-start gap-3 text-sm text-muted">
                <span class="mt-0.5 grid h-5 w-5 shrink-0 place-items-center rounded-full bg-mint-400/15 text-emerald-600"><Icon name="check" class="h-3.5 w-3.5" /></span>
                {r}
              </li>
            ))}
          </ul>
        </div>

        <!-- after install -->
        <div class="mt-10">
          <h3 class="text-center font-display text-2xl font-bold text-ink">After you install</h3>
          <div class="mt-6 grid gap-5 md:grid-cols-3">
            {firstRun.map((s, i) => (
              <div class="card p-6">
                <div class="grid h-9 w-9 place-items-center rounded-full bg-brand-600 font-display text-sm font-bold text-white">{i + 1}</div>
                <h4 class="mt-3 font-display text-lg font-semibold text-ink">{s.t}</h4>
                <p class="mt-1.5 text-sm text-muted">{s.b}</p>
              </div>
            ))}
          </div>
          <p class="mt-5 text-center text-sm text-faint">Next: <a href="/integrations#setup" class="font-semibold text-brand-600 hover:text-brand-700">connect your agents</a> · <a href="/gallery" class="font-semibold text-brand-600 hover:text-brand-700">adopt a pet</a></p>
        </div>
      </div>

      <!-- Windows panel -->
      <div data-panel="windows" class="tab-panel mt-8 hidden">
        <div class="text-center">
          <h3 class="font-display text-2xl font-bold text-ink">Two ways to install, pick one</h3>
          <p class="mx-auto mt-2 max-w-md text-muted">Run the installer, or unzip the portable build anywhere. You only need one of them.</p>
        </div>

        <div class="mt-7 flex flex-col items-stretch gap-5 md:flex-row">
          <div class="card relative flex flex-1 flex-col p-7">
            <span class="absolute right-5 top-6 rounded-full bg-mint-400/15 px-2.5 py-1 text-[10px] font-bold uppercase tracking-wide text-emerald-600">Recommended</span>
            <span class="grid h-12 w-12 place-items-center rounded-2xl bg-brand-50 text-brand-600"><Icon name="download" class="h-6 w-6" /></span>
            <div class="mt-4 font-pixel text-[11px] uppercase tracking-wide text-brand-500">Option 1</div>
            <h3 class="mt-0.5 font-display text-xl font-semibold text-ink">Installer</h3>
            <p class="mt-2 flex-1 text-muted">Grab the setup, run it, done. Installs per-user (no admin needed) and keeps itself up to date.</p>
            <a href={WIN_SETUP} class="btn-primary mt-4 w-full"><Icon name="windows" class="h-5 w-5" /> Download .exe</a>
            <a href={RELEASES} target="_blank" rel="noopener" class="mt-3 inline-flex items-center gap-1 self-start text-sm font-semibold text-brand-600 hover:text-brand-700">Browse all releases <Icon name="arrow" class="h-4 w-4" /></a>
          </div>

          <!-- either / or divider -->
          <div class="flex items-center justify-center gap-3 md:flex-col">
            <span class="h-px flex-1 bg-line md:h-auto md:w-px md:flex-1"></span>
            <span class="grid h-9 w-9 shrink-0 place-items-center rounded-full border border-line bg-white text-[11px] font-bold uppercase text-faint shadow-soft">or</span>
            <span class="h-px flex-1 bg-line md:h-auto md:w-px md:flex-1"></span>
          </div>

          <div class="card flex flex-1 flex-col p-7">
            <span class="grid h-12 w-12 place-items-center rounded-2xl bg-brand-50 text-brand-600"><Icon name="package" class="h-6 w-6" /></span>
            <div class="mt-4 font-pixel text-[11px] uppercase tracking-wide text-brand-500">Option 2</div>
            <h3 class="mt-0.5 font-display text-xl font-semibold text-ink">Portable</h3>
            <p class="mt-2 flex-1 text-muted">No installer, no traces. Unzip <code class="rounded bg-brand-50 px-1.5 py-0.5 font-mono text-xs text-brand-700">AgentPet-portable-x64.zip</code> anywhere and run <code class="rounded bg-brand-50 px-1.5 py-0.5 font-mono text-xs text-brand-700">AgentPet.exe</code>.</p>
            <a href={WIN_PORTABLE} class="btn-primary mt-4 w-full"><Icon name="windows" class="h-5 w-5" /> Download portable .zip</a>
          </div>
        </div>

        <!-- requirements -->
        <div class="card mt-5 p-7">
          <h3 class="font-display text-lg font-semibold text-ink">What you need</h3>
          <ul class="mt-4 grid gap-3 sm:grid-cols-2">
            {winRequirements.map((r) => (
              <li class="flex items-start gap-3 text-sm text-muted">
                <span class="mt-0.5 grid h-5 w-5 shrink-0 place-items-center rounded-full bg-mint-400/15 text-emerald-600"><Icon name="check" class="h-3.5 w-3.5" /></span>
                {r}
              </li>
            ))}
          </ul>
          <p class="mt-4 rounded-xl bg-sun-400/10 px-4 py-3 text-sm text-muted">Windows may show a SmartScreen warning on first run because this early build isn't code-signed yet. Click <b class="text-ink">More info → Run anyway</b>. The app is open source, you can audit every line on <a href={GITHUB} target="_blank" rel="noopener" class="font-semibold text-brand-600 hover:text-brand-700">GitHub</a>.</p>
        </div>

        <!-- after install -->
        <div class="mt-10">
          <h3 class="text-center font-display text-2xl font-bold text-ink">After you install</h3>
          <div class="mt-6 grid gap-5 md:grid-cols-3">
            {firstRunWin.map((s, i) => (
              <div class="card p-6">
                <div class="grid h-9 w-9 place-items-center rounded-full bg-brand-600 font-display text-sm font-bold text-white">{i + 1}</div>
                <h4 class="mt-3 font-display text-lg font-semibold text-ink">{s.t}</h4>
                <p class="mt-1.5 text-sm text-muted">{s.b}</p>
              </div>
            ))}
          </div>
          <p class="mt-5 text-center text-sm text-faint">Next: <a href="/integrations#setup" class="font-semibold text-brand-600 hover:text-brand-700">connect your agents</a> · <a href="/gallery" class="font-semibold text-brand-600 hover:text-brand-700">adopt a pet</a></p>
        </div>
      </div>

      <!-- Linux panel -->
      <div data-panel="linux" class="tab-panel mt-8 hidden">
        <div class="text-center">
          <h3 class="font-display text-2xl font-bold text-ink">One line, done</h3>
          <p class="mx-auto mt-2 max-w-lg text-muted">Downloads the latest AppImage and launches it. No root, works on any distro.</p>
        </div>
        <div class="mx-auto mt-5 max-w-2xl">
          <CodeBlock code={LINUX_ONELINE} lang="bash" />
        </div>

        <div class="mt-10 text-center">
          <h3 class="font-display text-2xl font-bold text-ink">Or pick a format</h3>
          <p class="mx-auto mt-2 max-w-md text-muted">A universal AppImage, or a native package for Debian/Ubuntu and Fedora. You only need one.</p>
        </div>

        <div class="mt-7 grid gap-5 md:grid-cols-3">
          <div class="card relative flex flex-col p-7">
            <span class="absolute right-5 top-6 rounded-full bg-mint-400/15 px-2.5 py-1 text-[10px] font-bold uppercase tracking-wide text-emerald-600">Any distro</span>
            <span class="grid h-12 w-12 place-items-center rounded-2xl bg-brand-50 text-brand-600"><Icon name="download" class="h-6 w-6" /></span>
            <h3 class="mt-4 font-display text-xl font-semibold text-ink">AppImage</h3>
            <p class="mt-2 flex-1 text-muted">Just chmod +x and run , no install, works on any distro.</p>
            <a href={LINUX_APPIMAGE} class="btn-primary mt-4 w-full"><Icon name="linux" class="h-5 w-5" /> Download .AppImage</a>
          </div>
          <div class="card flex flex-col p-7">
            <span class="grid h-12 w-12 place-items-center rounded-2xl bg-brand-50 text-brand-600"><Icon name="package" class="h-6 w-6" /></span>
            <h3 class="mt-4 font-display text-xl font-semibold text-ink">Debian / Ubuntu</h3>
            <p class="mt-2 flex-1 text-muted">A native .deb , installs with apt or dpkg and pulls its dependencies.</p>
            <a href={LINUX_DEB} class="btn-primary mt-4 w-full"><Icon name="linux" class="h-5 w-5" /> Download .deb</a>
          </div>
          <div class="card flex flex-col p-7">
            <span class="grid h-12 w-12 place-items-center rounded-2xl bg-brand-50 text-brand-600"><Icon name="package" class="h-6 w-6" /></span>
            <h3 class="mt-4 font-display text-xl font-semibold text-ink">Fedora / openSUSE</h3>
            <p class="mt-2 flex-1 text-muted">A native .rpm for rpm-based distros.</p>
            <a href={LINUX_RPM} class="btn-primary mt-4 w-full"><Icon name="linux" class="h-5 w-5" /> Download .rpm</a>
          </div>
        </div>

        <div class="mt-6">
          <CodeBlock code={LINUX_RUN} lang="bash" />
        </div>

        <!-- requirements -->
        <div class="card mt-5 p-7">
          <h3 class="font-display text-lg font-semibold text-ink">What you need</h3>
          <ul class="mt-4 grid gap-3 sm:grid-cols-2">
            {linuxRequirements.map((r) => (
              <li class="flex items-start gap-3 text-sm text-muted">
                <span class="mt-0.5 grid h-5 w-5 shrink-0 place-items-center rounded-full bg-mint-400/15 text-emerald-600"><Icon name="check" class="h-3.5 w-3.5" /></span>
                {r}
              </li>
            ))}
          </ul>
          <p class="mt-4 rounded-xl bg-sun-400/10 px-4 py-3 text-sm text-muted">This is an early Linux build , unsigned and without in-app auto-update yet, so grab new versions from <a href={RELEASES} target="_blank" rel="noopener" class="font-semibold text-brand-600 hover:text-brand-700">Releases</a>. It's open source, audit every line on <a href={GITHUB} target="_blank" rel="noopener" class="font-semibold text-brand-600 hover:text-brand-700">GitHub</a>.</p>
        </div>

        <!-- after install -->
        <div class="mt-10">
          <h3 class="text-center font-display text-2xl font-bold text-ink">After you install</h3>
          <div class="mt-6 grid gap-5 md:grid-cols-3">
            {firstRunLinux.map((s, i) => (
              <div class="card p-6">
                <div class="grid h-9 w-9 place-items-center rounded-full bg-brand-600 font-display text-sm font-bold text-white">{i + 1}</div>
                <h4 class="mt-3 font-display text-lg font-semibold text-ink">{s.t}</h4>
                <p class="mt-1.5 text-sm text-muted">{s.b}</p>
              </div>
            ))}
          </div>
          <p class="mt-5 text-center text-sm text-faint">Next: <a href="/integrations#setup" class="font-semibold text-brand-600 hover:text-brand-700">connect your agents</a> · <a href="/gallery" class="font-semibold text-brand-600 hover:text-brand-700">adopt a pet</a></p>
        </div>
      </div>
    </div>
  </section>

  <!-- uninstall -->
  <section id="uninstall" class="scroll-mt-28 px-4 pt-16">
    <div class="mx-auto max-w-6xl">
      <div class="text-center">
        <div class="font-pixel text-[11px] uppercase tracking-wide text-brand-500">Clean removal</div>
        <h2 class="mt-2 font-display text-3xl font-bold text-ink">Uninstall AgentPet</h2>
        <p class="mx-auto mt-3 max-w-xl text-muted">No leftovers. Disconnect your agents first so their config stays clean, then remove the app and its data.</p>
      </div>

      <div class="card mt-7 p-7">
        <ol class="space-y-6">
          <li class="flex gap-4">
            <span class="grid h-8 w-8 shrink-0 place-items-center rounded-full bg-brand-600 font-display text-sm font-bold text-white">1</span>
            <div>
              <h3 class="font-display text-lg font-semibold text-ink">Disconnect your agents</h3>
              <p class="mt-1 text-muted">In <b class="text-ink">Settings → General</b>, click <b class="text-ink">Remove</b> next to each agent you connected. This strips AgentPet's hooks from the agents' config so they don't error after the app is gone.</p>
            </div>
          </li>
          <li class="flex gap-4">
            <span class="grid h-8 w-8 shrink-0 place-items-center rounded-full bg-brand-600 font-display text-sm font-bold text-white">2</span>
            <div class="min-w-0 flex-1">
              <h3 class="font-display text-lg font-semibold text-ink">Remove the app and its data</h3>
              <p class="mt-1 mb-3 text-muted">Then delete the app along with downloaded pets and preferences:</p>
              <CodeBlock code={UNINSTALL} />
              <p class="mt-3 text-sm text-faint">Not using Homebrew? Drag <code class="rounded bg-brand-50 px-1.5 py-0.5 font-mono text-xs text-brand-700">/Applications/AgentPet.app</code> to the Trash instead. The <code class="rounded bg-brand-50 px-1.5 py-0.5 font-mono text-xs text-brand-700">~/.agentpet</code> folder holds your downloaded pets and state.</p>
            </div>
          </li>
        </ol>
      </div>
    </div>
  </section>

  <!-- build from source -->
  <section class="px-4 pt-12">
    <div class="mx-auto max-w-6xl">
      <div class="card p-7">
        <div class="flex items-center gap-3">
          <span class="grid h-10 w-10 place-items-center rounded-xl bg-brand-50 text-brand-600"><Icon name="package" class="h-5 w-5" /></span>
          <div>
            <h3 class="font-display text-lg font-semibold text-ink">Build from source</h3>
            <p class="text-sm text-muted">For hackers and contributors. Requires Xcode 16 / Swift 6.</p>
          </div>
        </div>
        <CodeBlock code={BUILD} class="mt-4" />
        <a href={`${GITHUB}/blob/main/CONTRIBUTING.md`} target="_blank" rel="noopener" class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-brand-600 hover:text-brand-700">Read the contributing guide <Icon name="arrow" class="h-4 w-4" /></a>
      </div>
    </div>
  </section>

  <script>
    // Platform tabs: toggle panels + selected styling.
    const tabs = Array.from(document.querySelectorAll<HTMLButtonElement>(".tab-btn"));
    const panels = Array.from(document.querySelectorAll<HTMLElement>(".tab-panel"));
    const active = "bg-brand-600 text-white shadow-soft";
    const idle = "text-muted hover:bg-brand-50 hover:text-brand-700";
    function select(id: string) {
      tabs.forEach((t) => {
        const on = t.dataset.tab === id;
        t.setAttribute("aria-selected", on ? "true" : "false");
        active.split(" ").forEach((c) => t.classList.toggle(c, on));
        idle.split(" ").forEach((c) => t.classList.toggle(c, !on));
        // status badge recolours for the selected (filled) tab
        const badge = t.querySelector("span");
        if (badge) {
          const avail = badge.textContent?.trim() === "Available";
          badge.className = `rounded-full px-2 py-0.5 text-[10px] font-bold uppercase tracking-wide ${
            avail ? (on ? "bg-white/20 text-white" : "bg-mint-400/15 text-emerald-600") : "bg-sun-400/20 text-amber-600"
          }`;
        }
      });
      panels.forEach((p) => p.classList.toggle("hidden", p.dataset.panel !== id));
    }
    tabs.forEach((t) => t.addEventListener("click", () => select(t.dataset.tab!)));

    // OS-aware default: show the visitor's platform tab + matching hero button.
    const ua = navigator.userAgent;
    const os = /Win(dows|32|64)/i.test(ua) ? "windows"
      : (/Linux|X11|Ubuntu/i.test(ua) && !/Android/i.test(ua)) ? "linux"
      : "macos";
    if (os !== "macos") {
      select(os);
      document.querySelectorAll<HTMLElement>("[data-os-cta]").forEach((el) => {
        el.classList.toggle("hidden", el.dataset.osCta !== os);
      });
    }
  </script>
</Base>
