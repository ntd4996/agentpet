<Window x:Class="AgentPet.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:AgentPet.Windows.Controls"
        Title="AgentPet" Height="740" Width="700"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource AppBgBrush}"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display">
    <Window.Resources>
        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Margin" Value="0,0,0,5" />
        </Style>
        <Style x:Key="VietnameseCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Margin" Value="0,4,0,10" />
        </Style>
        <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="#FF232631" />
            <Setter Property="BorderBrush" Value="{StaticResource DividerBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Root" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="TimeComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="#FF232631" />
            <Setter Property="BorderBrush" Value="#55FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                        <Setter Property="Background" Value="#FF232631" />
                        <Setter Property="Padding" Value="12,7" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="ItemRoot" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="ItemRoot" Property="Background" Value="{StaticResource AccentSoftBrush}" />
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="ItemRoot" Property="Background" Value="{StaticResource AccentBrush}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Root"
                                                Background="#FF232631"
                                                BorderBrush="#55FFFFFF"
                                                BorderThickness="1"
                                                CornerRadius="10"
                                                Padding="12,7">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  VerticalAlignment="Center"
                                                                  RecognizesAccessKey="True" />
                                                <Path Grid.Column="1"
                                                      Data="M 0 0 L 4 4 L 8 0 Z"
                                                      Fill="{StaticResource TextSecondaryBrush}"
                                                      Width="8"
                                                      Height="4"
                                                      Stretch="Fill"
                                                      Margin="10,0,0,0"
                                                      VerticalAlignment="Center" />
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   PopupAnimation="Fade">
                                <Border Background="#FF1D202B"
                                        BorderBrush="{StaticResource AccentBrush}"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="6"
                                        MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="260">
                                    <ScrollViewer CanContentScroll="True">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PetCardButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Width="108" Height="118" Padding="8" Background="#00151821" BorderBrush="#40FFFFFF" BorderThickness="1" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource CardHoverBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#66FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Margin="10" Background="{StaticResource AppBgBrush}" CornerRadius="16" BorderBrush="#28FFFFFF" BorderThickness="1" Effect="{StaticResource PanelShadow}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="112" />
                <RowDefinition Height="1" />
                <RowDefinition Height="*" />
                <RowDefinition Height="1" />
                <RowDefinition Height="58" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Button Style="{StaticResource TabButtonStyle}" Margin="4,0" Command="{Binding SelectGeneralTabCommand}"><StackPanel><TextBlock Text="⚙" FontSize="26" HorizontalAlignment="Center" /><TextBlock Text="Cài đặt" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center" /></StackPanel></Button>
                <Button Style="{StaticResource TabButtonStyle}" Margin="4,0" Command="{Binding SelectPetTabCommand}"><StackPanel><TextBlock Text="🐾" FontSize="26" HorizontalAlignment="Center" /><TextBlock Text="Thú cưng" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center" /></StackPanel></Button>
                <Button Style="{StaticResource TabButtonStyle}" Margin="4,0" Command="{Binding SelectBubbleTabCommand}"><StackPanel><TextBlock Text="💬" FontSize="26" HorizontalAlignment="Center" /><TextBlock Text="Bong bóng" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center" /></StackPanel></Button>
                <Button Style="{StaticResource TabButtonStyle}" Margin="4,0" Command="{Binding SelectAboutTabCommand}"><StackPanel><TextBlock Text="♥" FontSize="28" HorizontalAlignment="Center" /><TextBlock Text="Giới thiệu" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center" /></StackPanel></Button>
            </StackPanel>

            <Border Grid.Row="1" Background="{StaticResource DividerBrush}" />

            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <Grid Margin="24,22,24,16">
                    <StackPanel Visibility="{Binding GeneralTabVisibility}">
                        <Border Background="{StaticResource CardBrush}" CornerRadius="18" Padding="18" Effect="{StaticResource SoftShadow}">
                            <StackPanel>
                                <TextBlock Text="Nhắc việc hằng ngày" Style="{StaticResource SectionTitleStyle}" />
                                <CheckBox Content="Bật nhắc việc" IsChecked="{Binding RemindersEnabled}" Style="{StaticResource VietnameseCheckBoxStyle}" />
                                <TextBlock Text="Mỗi buổi có thể thêm nhiều việc. Chọn khung giờ bằng dropdown để pet nhắc đúng lúc." Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,12" />

                                <Border Background="{StaticResource PanelBrush}" CornerRadius="14" Padding="14" Margin="0,8,0,12">
                                    <StackPanel>
                                        <DockPanel>
                                            <CheckBox Content="Buổi sáng" IsChecked="{Binding MorningEnabled}" Style="{StaticResource VietnameseCheckBoxStyle}" DockPanel.Dock="Left" />
                                            <Button Content="+ Thêm việc" Style="{StaticResource RoundedButtonStyle}" Command="{Binding AddMorningTaskCommand}" HorizontalAlignment="Right" DockPanel.Dock="Right" />
                                        </DockPanel>
                                        <ItemsControl ItemsSource="{Binding MorningTasks}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#FF303442" BorderBrush="#26FFFFFF" BorderThickness="1" CornerRadius="16" Padding="14" Margin="0,0,0,12">
                                                        <StackPanel>
                                                            <DockPanel>
                                                                <CheckBox Content="Bật việc này" IsChecked="{Binding Enabled}" Style="{StaticResource VietnameseCheckBoxStyle}" DockPanel.Dock="Left" />
                                                                <Button Content="Xóa" Style="{StaticResource RoundedButtonStyle}" Command="{Binding DataContext.RemoveMorningTaskCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" HorizontalAlignment="Right" DockPanel.Dock="Right" />
                                                            </DockPanel>
                                                            <TextBlock Text="Việc cần nhắc" Style="{StaticResource LabelStyle}" />
                                                            <TextBox Style="{StaticResource InputTextBoxStyle}" Text="{Binding TaskText, UpdateSourceTrigger=PropertyChanged}" MinHeight="38" />
                                                            <Grid Margin="0,10,0,0">
                                                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="12" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                                                <StackPanel><TextBlock Text="Từ giờ" Style="{StaticResource LabelStyle}" /><ComboBox Style="{StaticResource TimeComboBoxStyle}" ItemsSource="{Binding DataContext.TimeOptions, RelativeSource={RelativeSource AncestorType=Window}}" SelectedItem="{Binding FromTime, UpdateSourceTrigger=PropertyChanged}" Height="38" /></StackPanel>
                                                                <StackPanel Grid.Column="2"><TextBlock Text="Đến giờ" Style="{StaticResource LabelStyle}" /><ComboBox Style="{StaticResource TimeComboBoxStyle}" ItemsSource="{Binding DataContext.TimeOptions, RelativeSource={RelativeSource AncestorType=Window}}" SelectedItem="{Binding ToTime, UpdateSourceTrigger=PropertyChanged}" Height="38" /></StackPanel>
                                                            </Grid>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>

                                <Border Background="{StaticResource PanelBrush}" CornerRadius="14" Padding="14" Margin="0,0,0,12">
                                    <StackPanel>
                                        <DockPanel>
                                            <CheckBox Content="Buổi chiều" IsChecked="{Binding AfternoonEnabled}" Style="{StaticResource VietnameseCheckBoxStyle}" DockPanel.Dock="Left" />
                                            <Button Content="+ Thêm việc" Style="{StaticResource RoundedButtonStyle}" Command="{Binding AddAfternoonTaskCommand}" HorizontalAlignment="Right" DockPanel.Dock="Right" />
                                        </DockPanel>
                                        <ItemsControl ItemsSource="{Binding AfternoonTasks}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#FF303442" BorderBrush="#26FFFFFF" BorderThickness="1" CornerRadius="16" Padding="14" Margin="0,0,0,12">
                                                        <StackPanel>
                                                            <DockPanel>
                                                                <CheckBox Content="Bật việc này" IsChecked="{Binding Enabled}" Style="{StaticResource VietnameseCheckBoxStyle}" DockPanel.Dock="Left" />
                                                                <Button Content="Xóa" Style="{StaticResource RoundedButtonStyle}" Command="{Binding DataContext.RemoveAfternoonTaskCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" HorizontalAlignment="Right" DockPanel.Dock="Right" />
                                                            </DockPanel>
                                                            <TextBlock Text="Việc cần nhắc" Style="{StaticResource LabelStyle}" />
                                                            <TextBox Style="{StaticResource InputTextBoxStyle}" Text="{Binding TaskText, UpdateSourceTrigger=PropertyChanged}" MinHeight="38" />
                                                            <Grid Margin="0,10,0,0">
                                                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="12" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                                                <StackPanel><TextBlock Text="Từ giờ" Style="{StaticResource LabelStyle}" /><ComboBox Style="{StaticResource TimeComboBoxStyle}" ItemsSource="{Binding DataContext.TimeOptions, RelativeSource={RelativeSource AncestorType=Window}}" SelectedItem="{Binding FromTime, UpdateSourceTrigger=PropertyChanged}" Height="38" /></StackPanel>
                                                                <StackPanel Grid.Column="2"><TextBlock Text="Đến giờ" Style="{StaticResource LabelStyle}" /><ComboBox Style="{StaticResource TimeComboBoxStyle}" ItemsSource="{Binding DataContext.TimeOptions, RelativeSource={RelativeSource AncestorType=Window}}" SelectedItem="{Binding ToTime, UpdateSourceTrigger=PropertyChanged}" Height="38" /></StackPanel>
                                                            </Grid>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="Kích thước thú cưng" Style="{StaticResource LabelStyle}" />
                                <DockPanel Margin="0,0,0,14"><TextBlock Text="{Binding PetSize}" Foreground="{StaticResource TextPrimaryBrush}" DockPanel.Dock="Right" Margin="12,0,0,0" VerticalAlignment="Center" /><Slider Minimum="96" Maximum="260" TickFrequency="1" Value="{Binding PetSize, UpdateSourceTrigger=PropertyChanged}" /></DockPanel>
                                <StackPanel Orientation="Horizontal"><Button Style="{StaticResource AccentButtonStyle}" Command="{Binding SaveSettingsCommand}" Margin="0,0,8,0"><TextBlock Text="Lưu cài đặt" /></Button><Button Style="{StaticResource RoundedButtonStyle}" Command="{Binding TestReminderCommand}"><TextBlock Text="Nhắc thử" /></Button></StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Visibility="{Binding PetTabVisibility}">
                        <Border Background="{StaticResource CardBrush}" CornerRadius="18" Padding="16" Effect="{StaticResource SoftShadow}"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="104" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><Border Width="88" Height="88" Background="#20FFFFFF" CornerRadius="14" HorizontalAlignment="Left" VerticalAlignment="Center"><controls:SpritePetView Mood="{Binding PreviewMood}" SpritesheetPath="{Binding SelectedPetSpritesheet}" Width="82" Height="82" HorizontalAlignment="Center" VerticalAlignment="Center" /></Border><StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="4,0,0,0"><TextBlock Text="{Binding SelectedPetName}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="21" FontWeight="Bold" /><TextBlock Text="{Binding SelectedPetDescription}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="14" TextWrapping="Wrap" Margin="0,6,0,0" /></StackPanel></Grid></Border>
                        <TextBlock Text="Chọn thú cưng" Foreground="{StaticResource TextPrimaryBrush}" FontSize="18" FontWeight="SemiBold" Margin="0,22,0,10" />
                        <Border Background="{StaticResource PanelBrush}" CornerRadius="16" Padding="14"><StackPanel><Grid><TextBox Style="{StaticResource SearchTextBoxStyle}" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" ToolTip="Tìm thú cưng" Height="48" /><TextBlock Text="Tìm thú cưng" Foreground="{StaticResource TextMutedBrush}" FontSize="14" Margin="16,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False"><TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding SearchText}" Value=""><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style></TextBlock.Style></TextBlock></Grid><Border Background="{StaticResource DividerBrush}" Height="1" Margin="0,12,0,14" /><TextBlock Text="{Binding EmptyStateText}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="14" HorizontalAlignment="Center" Margin="0,0,0,8" /><ItemsControl ItemsSource="{Binding PagedPets}"><ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Columns="4" Rows="2" MinHeight="260" /></ItemsPanelTemplate></ItemsControl.ItemsPanel><ItemsControl.ItemTemplate><DataTemplate><Button Style="{StaticResource PetCardButtonStyle}" Command="{Binding DataContext.SelectPetCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Margin="10"><Button.Resources><Style TargetType="Border" x:Key="PetCardChromeStyle"><Setter Property="Background" Value="Transparent" /><Setter Property="BorderBrush" Value="Transparent" /><Setter Property="BorderThickness" Value="0" /><Style.Triggers><DataTrigger Binding="{Binding IsSelected}" Value="True"><Setter Property="Background" Value="{StaticResource AccentSoftBrush}" /><Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" /><Setter Property="BorderThickness" Value="2" /></DataTrigger></Style.Triggers></Style></Button.Resources><Border Style="{StaticResource PetCardChromeStyle}" CornerRadius="10" Padding="6"><StackPanel HorizontalAlignment="Center"><Image Source="{Binding Thumbnail}" Width="58" Height="58" Stretch="Uniform" RenderOptions.BitmapScalingMode="NearestNeighbor" /><TextBlock Text="{Binding DisplayName}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="12" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" TextAlignment="Center" Width="86" Margin="0,8,0,0" /></StackPanel></Border></Button></DataTemplate></ItemsControl.ItemTemplate></ItemsControl><StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,4"><Button Content="‹" Width="36" Style="{StaticResource RoundedButtonStyle}" Command="{Binding PreviousPageCommand}" /><TextBlock Text="{Binding PageIndicator}" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="SemiBold" Margin="16,0" VerticalAlignment="Center" /><Button Content="›" Width="36" Style="{StaticResource RoundedButtonStyle}" Command="{Binding NextPageCommand}" /></StackPanel><Border Background="{StaticResource DividerBrush}" Height="1" Margin="0,12,0,14" /><StackPanel Orientation="Horizontal"><Button Style="{StaticResource RoundedButtonStyle}" Command="{Binding BrowseCommand}" Margin="0,0,8,0"><TextBlock Text="Mở thư mục thú cưng…" /></Button><Button Style="{StaticResource RoundedButtonStyle}" Command="{Binding CreateCommand}"><TextBlock Text="Tạo thú cưng…" /></Button></StackPanel></StackPanel></Border>
                    </StackPanel>

                    <StackPanel Visibility="{Binding BubbleTabVisibility}">
                        <Border Background="{StaticResource CardBrush}" CornerRadius="18" Padding="18" Effect="{StaticResource SoftShadow}">
                            <StackPanel>
                                <TextBlock Text="Bong bóng giao tiếp" Style="{StaticResource SectionTitleStyle}" />
                                <CheckBox Content="Hiện bong bóng khi đến giờ nhắc" IsChecked="{Binding ReminderBubblesEnabled}" Style="{StaticResource VietnameseCheckBoxStyle}" />
                                <TextBlock Text="Tôi nên gọi bạn là gì?" Style="{StaticResource LabelStyle}" />
                                <TextBox Style="{StaticResource InputTextBoxStyle}" Text="{Binding UserName, UpdateSourceTrigger=PropertyChanged}" MinHeight="38" />
                                <TextBlock Text="Tin nhắn mặc định" Style="{StaticResource LabelStyle}" Margin="0,12,0,5" />
                                <TextBox Style="{StaticResource InputTextBoxStyle}" Text="{Binding IdleBubbleText, UpdateSourceTrigger=PropertyChanged}" MinHeight="38" />
                                <TextBlock Text="Câu chào ({name})" Style="{StaticResource LabelStyle}" Margin="0,12,0,5" />
                                <TextBox Style="{StaticResource InputTextBoxStyle}" Text="{Binding GreetingPhrase, UpdateSourceTrigger=PropertyChanged}" MinHeight="38" />
                                <TextBlock Text="Câu nhắc việc ({name}, {task})" Style="{StaticResource LabelStyle}" Margin="0,12,0,5" />
                                <TextBox Style="{StaticResource InputTextBoxStyle}" Text="{Binding ReminderPhrase, UpdateSourceTrigger=PropertyChanged}" MinHeight="38" />
                                <TextBlock Text="Câu động viên ({name})" Style="{StaticResource LabelStyle}" Margin="0,12,0,5" />
                                <TextBox Style="{StaticResource InputTextBoxStyle}" Text="{Binding EncouragementPhrase, UpdateSourceTrigger=PropertyChanged}" MinHeight="38" />
                                <TextBlock Text="Thời gian hiển thị (giây)" Style="{StaticResource LabelStyle}" Margin="0,14,0,5" />
                                <DockPanel Margin="0,0,0,14"><TextBlock Text="{Binding BubbleDurationSeconds}" Foreground="{StaticResource TextPrimaryBrush}" DockPanel.Dock="Right" Margin="12,0,0,0" VerticalAlignment="Center" /><Slider Minimum="3" Maximum="60" TickFrequency="1" Value="{Binding BubbleDurationSeconds, UpdateSourceTrigger=PropertyChanged}" /></DockPanel>
                                <TextBlock Text="Độ rộng bóng chat" Style="{StaticResource LabelStyle}" Margin="0,0,0,5" />
                                <DockPanel Margin="0,0,0,14"><TextBlock Text="{Binding BubbleWidth}" Foreground="{StaticResource TextPrimaryBrush}" DockPanel.Dock="Right" Margin="12,0,0,0" VerticalAlignment="Center" /><Slider Minimum="260" Maximum="520" TickFrequency="10" Value="{Binding BubbleWidth, UpdateSourceTrigger=PropertyChanged}" /></DockPanel>
                                <StackPanel Orientation="Horizontal"><Button Style="{StaticResource AccentButtonStyle}" Command="{Binding SaveSettingsCommand}" Margin="0,0,8,0"><TextBlock Text="Lưu cài đặt" /></Button><Button Style="{StaticResource RoundedButtonStyle}" Command="{Binding PreviewBubbleCommand}"><TextBlock Text="Xem thử bong bóng" /></Button></StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Visibility="{Binding AboutTabVisibility}">
                        <Border Background="{StaticResource CardBrush}" CornerRadius="18" Padding="22" Effect="{StaticResource SoftShadow}">
                            <StackPanel>
                                <TextBlock Text="AgentPet" Foreground="{StaticResource TextPrimaryBrush}" FontSize="26" FontWeight="Bold" />
                                <TextBlock Text="Thú cưng nhắc việc trên màn hình." Foreground="{StaticResource TextSecondaryBrush}" FontSize="16" Margin="0,8,0,0" TextWrapping="Wrap" />
                                <TextBlock Text="Cách dùng nhanh" Style="{StaticResource SectionTitleStyle}" Margin="0,22,0,10" />
                                <TextBlock Text="• Click 1 lần vào pet: xem việc đang làm và khung giờ của việc đó." Foreground="{StaticResource TextSecondaryBrush}" FontSize="14" TextWrapping="Wrap" Margin="0,0,0,6" />
                                <TextBlock Text="• Click đúp: chuyển sang việc kế tiếp." Foreground="{StaticResource TextSecondaryBrush}" FontSize="14" TextWrapping="Wrap" Margin="0,0,0,6" />
                                <TextBlock Text="• Click 3 lần: xác nhận đã hoàn thành việc hiện tại, pet sẽ báo việc kế tiếp." Foreground="{StaticResource TextSecondaryBrush}" FontSize="14" TextWrapping="Wrap" Margin="0,0,0,6" />
                                <TextBlock Text="• Mỗi 30 giây pet nhắc lại việc đang làm; khi còn 15, 10, 5 phút sẽ có âm báo nếu bạn chưa xác nhận xong." Foreground="{StaticResource TextSecondaryBrush}" FontSize="14" TextWrapping="Wrap" Margin="0,0,0,6" />
                                <TextBlock Text="• Nếu hoàn thành sớm và click 3 lần, pet sẽ phát âm chúc mừng và tính thời gian rảnh còn dư." Foreground="{StaticResource TextSecondaryBrush}" FontSize="14" TextWrapping="Wrap" Margin="0,0,0,6" />
                                <TextBlock Text="Cài đặt và pet cá nhân được lưu trong %LOCALAPPDATA%\AgentPet." Foreground="{StaticResource TextMutedBrush}" FontSize="13" TextWrapping="Wrap" Margin="0,12,0,0" />
                                <Button Style="{StaticResource RoundedButtonStyle}" Command="{Binding CheckForUpdatesCommand}" HorizontalAlignment="Left" Margin="0,16,0,0"><TextBlock Text="Kiểm tra cập nhật" /></Button>
                                <TextBlock Text="Được phát triển bởi Leon • 93 MEDIA" Foreground="{StaticResource TextPrimaryBrush}" FontSize="16" FontWeight="SemiBold" Margin="0,18,0,0" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </ScrollViewer>

            <Border Grid.Row="3" Background="{StaticResource DividerBrush}" />
            <DockPanel Grid.Row="4" Margin="18,0"><Button Style="{StaticResource AccentButtonStyle}" DockPanel.Dock="Left" Command="{Binding TogglePreviewCommand}"><StackPanel Orientation="Horizontal"><TextBlock Text="✨" Margin="0,0,8,0" /><TextBlock Text="{Binding PreviewButtonText}" /></StackPanel></Button><TextBlock Text="{Binding StatusText}" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="12,0,0,0" /></DockPanel>
        </Grid>
    </Border>
</Window>
